{
  "buildCommand": "npm test && node scripts/generate-config.mjs",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [{ "source": "/((?!assets|css|js|supabase|docs).*)", "destination": "/index.html" }]
}
